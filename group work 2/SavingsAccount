public class SavingsAccount extends Account {

    private static final double INTEREST_RATE = 0.002;

    public SavingsAccount(String accountNumber) {
        super(accountNumber);
    }

    @Override
    public boolean withdraw(double amount) {
        if (getBalance() < amount) {
            System.out.println("You don't have enough money to make the withdrawal!");
            System.out.println("Your balance is $" + getBalance());
            return false;
        }

        setBalance(getBalance() - amount);

        // Apply interest
        double newBalance = getBalance() + (getBalance() * INTEREST_RATE);
        setBalance(newBalance);

        System.out.println("$" + amount + " has been withdrawn from your account!");
        System.out.println("Your new balance is $" + String.format("%.2f", newBalance) + " (Interest Applied)");
        return true;
    }
}
